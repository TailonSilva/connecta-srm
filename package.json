{
  "name": "crm-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "CRM desktop com Electron, React, Express e SQLite.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:webapp": "concurrently -k \"npm:dev:backend\" \"npm:dev:web\"",
    "dev:backend": "nodemon server/index.js",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:3001 tcp:5173 && electron .",
    "start:backend": "node server/index.js",
    "start:web": "vite",
    "start:electron": "electron .",
    "build": "npm run build:web",
    "build:web": "vite build",
    "build:electron": "npm run build:web && electron-builder",
    "popular:banco": "node server/scripts/popularBanco.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "nodemon": "^3.1.10",
    "vite": "^7.1.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.crm.desktop",
    "productName": "CRM Desktop",
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "dist/web/**/*",
      "package.json"
    ]
  }
}
